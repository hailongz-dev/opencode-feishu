# Feishu / Lark application credentials
# Create an app at https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Feishu webhook verification token (from Event Subscription settings)
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Feishu encrypt key (optional, for encrypted callbacks)
FEISHU_ENCRYPT_KEY=

# OpenCode server base URL (default: http://localhost:4096)
OPENCODE_BASE_URL=http://localhost:4096

# Port for this webhook server to listen on (default: 3000)
PORT=3000
